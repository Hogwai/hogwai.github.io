---
import "../styles/global.css";
import { getLocalePath, getAlternateUrl, getOtherLang, type Lang } from "../i18n/utils";
import { defaultLang } from "../i18n/ui";

interface Props {
  title: string;
  description?: string;
  image?: string;
  ogType?: "website" | "article";
  publishedTime?: string;
  modifiedTime?: string;
  tags?: string[];
  lang?: Lang;
}

const { title, description = "Hogwai Tech Blog", image, ogType = "website", publishedTime, modifiedTime, tags, lang = defaultLang } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const otherLang = getOtherLang(lang);
const alternateURL = new URL(getAlternateUrl(Astro.url, otherLang), Astro.site);
const xDefaultURL = lang === defaultLang ? canonicalURL : alternateURL;
const imageURL = image ? new URL(image, Astro.site).href : undefined;
const siteJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "Hogwai Tech Blog",
  url: Astro.site?.href ?? "https://hogwai.github.io",
};
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta name="generator" content={Astro.generator} />
    <meta name="google-site-verification" content="Bp-Nwd3CbHnQjYafsGPLBcIS5qHvfJIcvhc9Zaej6nE" />
    <link rel="canonical" href={canonicalURL} />
    <link rel="alternate" hreflang={lang} href={canonicalURL} />
    <link rel="alternate" hreflang={otherLang} href={alternateURL} />
    <link rel="alternate" hreflang="x-default" href={xDefaultURL} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Lilian" />
    <link rel="author" href={`${getLocalePath(lang)}/about`} />
    <meta name="theme-color" content="#2563eb" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#1e3a5f" media="(prefers-color-scheme: dark)" />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="Hogwai Tech Blog" />
    <meta property="og:locale" content={lang === "fr" ? "fr_FR" : "en_US"} />
    {ogType === "article" && publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {ogType === "article" && modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
    {ogType === "article" && tags?.map((tag) => <meta property="article:tag" content={tag} />)}
    {imageURL && <meta property="og:image" content={imageURL} />}
    {imageURL && <meta property="og:image:alt" content={title} />}

    <meta name="twitter:card" content={imageURL ? "summary_large_image" : "summary"} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {imageURL && <meta name="twitter:image" content={imageURL} />}
    {imageURL && <meta name="twitter:image:alt" content={title} />}

    <link
      rel="alternate"
      type="application/rss+xml"
      title="Hogwai Tech Blog RSS Feed"
      href={`${getLocalePath(lang)}/rss.xml`}
    />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="dns-prefetch" href="https://cloud.umami.is" />
    <link rel="manifest" href="/manifest.json" />
    <script type="application/ld+json" set:html={JSON.stringify(siteJsonLd)} />

    <slot name="head" />

    <script is:inline>
      const theme =
        localStorage.getItem("theme") ||
        (window.matchMedia("(prefers-color-scheme: dark)").matches
          ? "dark"
          : "light");
      document.documentElement.classList.toggle("dark", theme === "dark");
    </script>
    <script is:inline>
      (function () {
        var defined = "preferred-lang";
        var stored;
        try { stored = localStorage.getItem(defined); } catch (e) {}
        var target = stored || (navigator.language.startsWith("fr") ? "fr" : "en");
        var path = location.pathname;
        // Skip non-content paths
        if (/\.(xml|json)$/.test(path) || path.startsWith("/rss")) return;
        var isFr = /^\/fr(\/|$)/.test(path);
        var currentLang = isFr ? "fr" : "en";
        if (target === currentLang) return;
        var newPath;
        if (target === "fr") {
          newPath = path === "/" ? "/fr/" : "/fr" + path;
        } else {
          newPath = path.replace(/^\/fr(\/|$)/, "/") || "/";
        }
        location.replace(newPath);
      })();
    </script>
    {
      import.meta.env.PROD && (
        <script
          is:inline
          defer
          src="https://cloud.umami.is/script.js"
          data-website-id="be4da73f-7653-4f79-8c0e-8e517de6dbba"
        />
      )
    }

    <style is:global>
      html {
        scroll-padding-top: 5rem;
      }
    </style>
  </head>
  <body class="min-h-screen flex flex-col">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-[100] focus:px-4 focus:py-2 focus:bg-accent-600 focus:text-white focus:rounded">
      Skip to content
    </a>
    <slot />
  </body>
</html>
