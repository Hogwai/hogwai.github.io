---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header';
import Footer from '../../../components/Footer';
import BlogCard from '../../../components/BlogCard';
import NoteCard from '../../../components/NoteCard';
import { getCollection } from 'astro:content';
import { useTranslations, getSlugWithoutLang, getLocalePath } from '../../../i18n/utils';
import { flags, type Lang } from '../../../i18n/ui';

const lang: Lang = "fr";
const t = useTranslations(lang);
const prefix = getLocalePath(lang);

export async function getStaticPaths() {
  const allPosts = (await getCollection('posts')).filter((p) => !p.data.draft);
  const allNotes = (await getCollection('notes')).filter((n) => !n.data.draft);

  const tagSet = new Set<string>();
  for (const post of allPosts) post.data.tags.forEach((t) => tagSet.add(t));
  for (const note of allNotes) note.data.tags.forEach((t) => tagSet.add(t));

  return [...tagSet].map((tag) => {
    const frPosts = allPosts.filter((p) => p.slug.startsWith('fr/') && p.data.tags.includes(tag));
    const enPosts = allPosts.filter((p) => p.slug.startsWith('en/') && p.data.tags.includes(tag));
    const frPostSlugs = new Set(frPosts.map((p) => getSlugWithoutLang(p.slug)));
    const enOnlyPosts = enPosts.filter((p) => !frPostSlugs.has(getSlugWithoutLang(p.slug)));

    const frNotes = allNotes.filter((n) => n.slug.startsWith('fr/') && n.data.tags.includes(tag));
    const enNotes = allNotes.filter((n) => n.slug.startsWith('en/') && n.data.tags.includes(tag));
    const frNoteSlugs = new Set(frNotes.map((n) => getSlugWithoutLang(n.slug)));
    const enOnlyNotes = enNotes.filter((n) => !frNoteSlugs.has(getSlugWithoutLang(n.slug)));

    return {
      params: { tag },
      props: {
        posts: [
          ...frPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()).map(p => ({ item: p, itemLang: "fr" as const, badge: undefined })),
          ...enOnlyPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()).map(p => ({ item: p, itemLang: "en" as const, badge: flags.en })),
        ],
        notes: [
          ...frNotes.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()).map(n => ({ item: n, itemLang: "fr" as const, badge: undefined })),
          ...enOnlyNotes.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()).map(n => ({ item: n, itemLang: "en" as const, badge: flags.en })),
        ],
      },
    };
  });
}

const { tag } = Astro.params;
const { posts, notes } = Astro.props;
---

<BaseLayout title={`#${tag}`} description={`Articles et notes avec le tag "${tag}" sur Hogwai Tech Blog.`} lang={lang}>
  <Header lang={lang} currentPath={Astro.url.pathname} client:visible />

  <main id="main-content" class="flex-grow bg-page">
    <div class="container-custom py-12">
      <div class="mb-2 text-sm text-ink-muted">
        <a href={`${prefix}/tags`} class="hover:text-link transition">
          &larr; {t("tags.backLink")}
        </a>
      </div>
      <h1 class="text-4xl md:text-5xl font-bold mb-8 text-ink">
        #{tag}
      </h1>

      {posts.length > 0 && (
        <section class="mb-10">
          <h2 class="text-2xl font-bold text-ink mb-4">{t("tags.postsSection")}</h2>
          <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
            {posts.map(({ item: post, itemLang, badge }) => (
              <BlogCard
                title={post.data.title}
                description={post.data.description}
                pubDate={post.data.pubDate}
                slug={getSlugWithoutLang(post.slug)}
                tags={post.data.tags}
                lang={itemLang}
                langBadge={badge}
                client:idle
              />
            ))}
          </div>
        </section>
      )}

      {notes.length > 0 && (
        <section>
          <h2 class="text-2xl font-bold text-ink mb-4">{t("tags.notesSection")}</h2>
          <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
            {notes.map(({ item: note, itemLang, badge }) => (
              <NoteCard
                title={note.data.title}
                description={note.data.description}
                pubDate={note.data.pubDate}
                slug={getSlugWithoutLang(note.slug)}
                tags={note.data.tags}
                language={note.data.language}
                lang={itemLang}
                langBadge={badge}
                client:idle
              />
            ))}
          </div>
        </section>
      )}
    </div>
  </main>

  <Footer lang={lang} />
</BaseLayout>
