---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header';
import Footer from '../../components/Footer';
import ProjectCard, { type Project } from '../../components/ProjectCard';
import projectsData from '../../data/projects.json';
import { useTranslations } from '../../i18n/utils';
import type { Lang } from '../../i18n/ui';

const lang: Lang = "fr";
const t = useTranslations(lang);

const projects = projectsData as Project[];
---

<BaseLayout title={t("projects.title")} description={t("projects.description")} lang={lang}>
  <Header lang={lang} currentPath={Astro.url.pathname} client:visible />

  <main id="main-content" class="flex-grow bg-page">
    <div class="container-custom py-12">
      <div class="mb-12">
        <h1 class="text-4xl md:text-5xl font-bold mb-4 text-ink">
          {t("projects.title")}
        </h1>
        <p class="text-xl text-ink">
          {t("projects.subtitle")}
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-6">
        {projects.map((project) => (
          <ProjectCard
            title={project.title}
            description={project.description_fr || project.description}
            technologies={project.technologies}
            links={project.links}
            image={project.image}
            client:visible
          />
        ))}
      </div>
    </div>
  </main>

  <Footer lang={lang} />
</BaseLayout>
