---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header";
import Footer from "../../components/Footer";
import { useTranslations } from "../../i18n/utils";
import type { Lang } from "../../i18n/ui";

const lang: Lang = "fr";
const t = useTranslations(lang);

const personJsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Lilian",
  url: "https://hogwai.github.io",
  jobTitle: "Software Developer",
  sameAs: [
    "https://github.com/Hogwai",
    "https://www.linkedin.com/in/lilian-wernert/",
  ],
};
---

<BaseLayout title={t("about.title")} description={t("about.description")} lang={lang}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(personJsonLd)} />
  </Fragment>
  <Header lang={lang} currentPath={Astro.url.pathname} client:visible />

  <main id="main-content" class="flex-grow bg-page">
    <div class="container-custom py-12">
      <h1
        class="text-4xl md:text-5xl font-bold mb-8 text-ink"
      >
        {t("about.title")}
      </h1>

      <div class="prose prose prose-sm max-w-none">
        <p class="text-xl text-ink mb-6">
          {t("about.welcome")}
        </p>

        <h2
          class="text-2xl font-bold mt-8 mb-4 text-ink"
        >
          {t("about.whoAmI")}
        </h2>
        <p class="text-ink">
          {t("about.whoAmIText")}
        </p>
        <h2
          class="text-2xl font-bold mt-8 mb-4 text-ink"
        >
          {t("about.theStack")}
        </h2>
        <p class="text-ink">
          {t("about.theStackText")} <a href="https://github.com/withastro/astro" target="_blank">Astro</a>, <a href="https://github.com/facebook/react" target="_blank">React</a>, <a href="https://github.com/microsoft/TypeScript" target="_blank">TypeScript</a> et <a href="https://github.com/tailwindlabs/tailwindcss" target="_blank">Tailwind CSS</a>.
        </p>
      </div>
    </div>
  </main>

  <Footer lang={lang} />
</BaseLayout>
