---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header';
import Footer from '../components/Footer';
import BlogCard from '../components/BlogCard';
import NoteCard from '../components/NoteCard';
import { getCollection } from 'astro:content';
import { useTranslations, getSlugWithoutLang } from '../i18n/utils';

const lang = "en" as const;
const t = useTranslations(lang);

const posts = (await getCollection('posts'))
  .filter(post => !post.data.draft && post.slug.startsWith('en/'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const recentNotes = (await getCollection('notes'))
  .filter(note => !note.data.draft && note.slug.startsWith('en/'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<BaseLayout title="Hogwai Tech Blog" description="Thoughts, tutorials and technical posts about Java and the JVM ecosystem." lang={lang}>
  <Header lang={lang} currentPath={Astro.url.pathname} client:load />

  <main id="main-content" class="flex-grow">
    <div class="container-custom pt-8 pb-6 border-b border-edge">
      <h1 class="text-lg text-ink-muted">{t("home.subtitle")}</h1>
    </div>

    <section class="container-custom py-8">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-2xl font-bold text-ink">{t("home.latestPosts")}</h2>
        <a href="/posts" class="text-sm text-link hover:underline">
          {t("home.seeAllPosts")} &rarr;
        </a>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
        {posts.map((post) => (
          <BlogCard
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            slug={getSlugWithoutLang(post.slug)}
            tags={post.data.tags}
            lang={lang}
            client:idle
          />
        ))}
      </div>
    </section>

    {recentNotes.length > 0 && (
      <section class="container-custom py-5">
        <div class="flex items-center justify-between mb-6">
          <h2 class="text-2xl font-bold text-ink">{t("home.recentNotes")}</h2>
          <a href="/notes" class="text-sm text-link hover:underline">
            {t("home.seeAllNotes")} &rarr;
          </a>
        </div>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
          {recentNotes.map((note) => (
            <NoteCard
              title={note.data.title}
              description={note.data.description}
              pubDate={note.data.pubDate}
              slug={getSlugWithoutLang(note.slug)}
              tags={note.data.tags}
              language={note.data.language}
              lang={lang}
              client:idle
            />
          ))}
        </div>
      </section>
    )}
  </main>

  <Footer lang={lang} />
</BaseLayout>
