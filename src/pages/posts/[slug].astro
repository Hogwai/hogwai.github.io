---
import { getCollection, render } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';
import { getSlugWithoutLang } from '../../i18n/utils';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  const enPosts = posts.filter((p) => p.id.startsWith('en/'));
  return enPosts.map((post) => ({
    params: { slug: getSlugWithoutLang(post.id) },
    props: post,
  }));
}

const post = Astro.props;
const { Content, headings, remarkPluginFrontmatter } = await render(post);
---

<BlogPost {...post.data} headings={headings} minutesRead={remarkPluginFrontmatter.minutesRead}>
  <Content />
</BlogPost>
