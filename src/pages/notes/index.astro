---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header';
import Footer from '../../components/Footer';
import NotesSearchAndFilter from '../../components/NotesSearchAndFilter';
import { getCollection } from 'astro:content';
import { useTranslations, getSlugWithoutLang } from '../../i18n/utils';
import { flags, type Lang } from '../../i18n/ui';

const lang: Lang = "en";
const t = useTranslations(lang);

const allNotes = (await getCollection('notes')).filter(n => !n.data.draft);
const enNotes = allNotes
  .filter(n => n.slug.startsWith('en/'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .map(n => ({ ...n, slug: getSlugWithoutLang(n.slug) }));
const frNotes = allNotes.filter(n => n.slug.startsWith('fr/'));
const enSlugSet = new Set(enNotes.map(n => n.slug));
const frOnlyNotes = frNotes
  .filter(n => !enSlugSet.has(getSlugWithoutLang(n.slug)))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .map(n => ({ ...n, slug: getSlugWithoutLang(n.slug), langBadge: flags.fr, lang: "fr" as const }));

const notes = [
  ...enNotes.map(n => ({ ...n, langBadge: undefined, lang: "en" as const })),
  ...frOnlyNotes,
].sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title={t("notes.title")} description={t("notes.description")} lang={lang}>
  <Header lang={lang} currentPath={Astro.url.pathname} client:visible />

  <main id="main-content" class="flex-grow bg-page">
    <div class="container-custom py-12">
      <div class="mb-8">
        <h1 class="text-4xl md:text-5xl font-bold mb-2 text-ink">{t("notes.title")}</h1>
        <p class="text-ink">{t("notes.subtitle")}</p>
      </div>

      <NotesSearchAndFilter notes={notes} lang={lang} client:visible />
    </div>
  </main>

  <Footer lang={lang} />
</BaseLayout>
